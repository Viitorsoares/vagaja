generator client {
  provider = "prisma"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model agent {
  id           Int            @id @default(autoincrement())
  nome         String         @db.VarChar(90)
  lastName    String         @db.VarChar(90)
  birthDate    DateTime       @db.Date
  phone        String
  cpf          String
  email        String         @unique
  password     String
  created_on   DateTime       @default(now())
  parkingSpots parking_spot[]
}

enum StatusVagas {
  Livre
  Ocupada
}

model parking_spot {
  id          Int         @id @default(autoincrement())
  longitude   Float
  latitude    Float
  status      StatusVagas @default(Livre)
  released_on DateTime    @default(now())
  agent_id    Int
  agent       agent       @relation(fields: [agent_id], references: [id])
}
